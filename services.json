{
  "protocol": "TCP",
  "services": [
    {
      "name": "ServiceA",
      "role": "server",
      "host": "127.0.0.1",
      "listen_port": 9000,
      "endpoints": [
        {
          "name": "receiveMessage",
          "input": "Message"
        }
      ]
    },
    {
      "name": "ServiceB",
      "role": "client",
      "host": "127.0.0.1",
      "target_port": 9000,
      "endpoints": [
        {
          "name": "sendMessage",
          "input": "Message"
        }
      ]
    }
  ],
  "messages": {
    "Message": {
      "id": "int",
      "text": "string"
    }
  }
}